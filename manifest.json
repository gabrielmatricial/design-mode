{
  "manifest_version": 3,
  "name": "Design Mode",
  "version": "1.0.0",
  "description": "Liga/desliga o design-mode.js na aba atual. Injeta o arquivo real do repo (sempre fresco) — sem bookmarklet, sem servidor.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "Design Mode (clique = liga/alterna)",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "permissions": ["scripting", "activeTab", "alarms"],
  "host_permissions": ["<all_urls>"],
  "background": { "service_worker": "bg.js" },
  "commands": {
    "_execute_action": {
      "suggested_key": { "default": "Alt+D" },
      "description": "Liga / alterna o Design Mode na aba atual"
    }
  }
}
